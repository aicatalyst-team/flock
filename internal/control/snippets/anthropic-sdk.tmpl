# Anthropic Python SDK → Flock

from anthropic import Anthropic

client = Anthropic(
    base_url="{{.BaseURL}}",
    api_key="{{.Token}}",
)

resp = client.messages.create(
    model="{{.Model}}",
    max_tokens=64,
    messages=[{"role": "user", "content": "hi in 5 words"}],
)
print(resp.content[0].text)

