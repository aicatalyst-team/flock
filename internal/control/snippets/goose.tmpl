# Goose → Flock (OpenAI-compatible provider)
# Edit ~/.config/goose/config.yaml:

GOOSE_PROVIDER: openai
GOOSE_MODEL: {{.Model}}
OPENAI_BASE_URL: {{.BaseURL}}/v1
OPENAI_API_KEY: {{.Token}}

# Or run `goose configure` interactively and pick "OpenAI Compatible"
# with the URL, key, and model above.

goose session                       # start an interactive session
goose run "summarize this repo"     # one-shot
