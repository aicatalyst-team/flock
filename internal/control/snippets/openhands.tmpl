# OpenHands → Flock (OpenAI or Anthropic, via LLM_BASE_URL / LLM_API_KEY)
# OpenHands runs in Docker by default. Pass the LLM env vars when launching:

docker run -it --rm --pull=always \
  -e SANDBOX_RUNTIME_CONTAINER_IMAGE=docker.all-hands.dev/all-hands-ai/runtime:latest \
  -e LLM_BASE_URL={{.BaseURL}}/v1 \
  -e LLM_API_KEY={{.Token}} \
  -e LLM_MODEL=openai/{{.Model}} \
  -v /var/run/docker.sock:/var/run/docker.sock \
  -v ~/.openhands:/.openhands \
  -p 3000:3000 \
  --add-host host.docker.internal:host-gateway \
  --name openhands \
  docker.all-hands.dev/all-hands-ai/openhands:latest

# Open http://localhost:3000 — the model picker auto-populates from Flock's /v1/models.

# For Anthropic-shape (Claude Code-style flows) inside OpenHands, set:
#   LLM_MODEL=anthropic/{{.Model}}
# and OpenHands will route via the Anthropic adapter at {{.BaseURL}}.
