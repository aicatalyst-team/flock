# OpenCode → Flock (OpenAI + Anthropic baseURL override)
# Put this in opencode.json at the project root (or ~/.config/opencode/opencode.json)

{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openai": {
      "options": {
        "baseURL": "{{.BaseURL}}/v1",
        "apiKey":  "{{.Token}}"
      }
    },
    "anthropic": {
      "options": {
        "baseURL": "{{.BaseURL}}",
        "apiKey":  "{{.Token}}"
      }
    }
  },
  "model": "{{.Model}}"
}

# Run: opencode
# Override per-session: opencode --model {{.Model}}
