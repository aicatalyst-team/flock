# Zed → Flock (OpenAI API)
# Add to ~/.config/zed/settings.json:

{
  "language_models": {
    "openai_compatible": {
      "Flock": {
        "api_url": "{{.BaseURL}}/v1",
        "available_models": [
          { "name": "{{.Model}}", "max_tokens": 32768 }
        ]
      }
    }
  }
}

# Then set the API key in Zed: ⌘P → "assistant: configure" → paste:
#   {{.Token}}
