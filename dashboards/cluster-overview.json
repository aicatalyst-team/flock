{
  "annotations": {"list": []},
  "description": "Flock cluster-wide health: throughput, latency, error rate, nodes & loaded models.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Requests/s (all models, all protocols)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum(rate(flock_requests_total[1m]))", "legendFormat": "RPS", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps", "min": 0}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "options": {"legend": {"showLegend": true}, "tooltip": {"mode": "multi"}}
    },
    {
      "title": "Error rate (4xx + 5xx + timeout outcomes)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "100 * sum(rate(flock_requests_total{outcome!~\"ok|success\"}[5m])) / clamp_min(sum(rate(flock_requests_total[5m])), 0.001)", "legendFormat": "err%", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 1, "color": "yellow"}, {"value": 5, "color": "red"}]}}, "overrides": []},
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0},
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    },
    {
      "title": "Nodes up",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum(flock_node_up == 1)", "legendFormat": "up", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "none", "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 1, "color": "green"}]}}, "overrides": []},
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0},
      "options": {"colorMode": "background", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    },
    {
      "title": "Latency (p50 / p95 / p99 across all models)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(flock_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum(rate(flock_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum(rate(flock_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "options": {"legend": {"showLegend": true, "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "title": "Tokens/s (prompt vs completion)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum(rate(flock_request_tokens_total{direction=\"prompt\"}[1m]))", "legendFormat": "prompt", "refId": "A"},
        {"expr": "sum(rate(flock_request_tokens_total{direction=\"completion\"}[1m]))", "legendFormat": "completion", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "tps", "min": 0}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "options": {"legend": {"showLegend": true, "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "title": "Loaded models per node",
      "type": "table",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "flock_model_loaded == 1", "format": "table", "instant": true, "refId": "A"}
      ],
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {"Time": true, "__name__": true, "Value": true, "instance": true, "job": true}, "renameByName": {"model": "Model", "node": "Node"}}}
      ],
      "options": {"showHeader": true}
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["flock"],
  "templating": {
    "list": [
      {
        "current": {"selected": false, "text": "default", "value": "default"},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Flock — Cluster Overview",
  "uid": "flock-cluster-overview",
  "version": 1,
  "weekStart": ""
}
