{
  "annotations": {"list": []},
  "description": "Flock per-model performance: RPS, latency percentiles, token rate, error rate. Select a model from the dropdown.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Requests/s",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum by (protocol) (rate(flock_requests_total{model=~\"$model\"}[1m]))", "legendFormat": "{{protocol}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps", "min": 0}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "options": {"legend": {"showLegend": true, "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "title": "Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(flock_request_duration_seconds_bucket{model=~\"$model\"}[5m])) by (le))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum(rate(flock_request_duration_seconds_bucket{model=~\"$model\"}[5m])) by (le))", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum(rate(flock_request_duration_seconds_bucket{model=~\"$model\"}[5m])) by (le))", "legendFormat": "p99", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "options": {"legend": {"showLegend": true, "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "title": "Tokens/s (prompt vs completion)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum(rate(flock_request_tokens_total{model=~\"$model\", direction=\"prompt\"}[1m]))", "legendFormat": "prompt", "refId": "A"},
        {"expr": "sum(rate(flock_request_tokens_total{model=~\"$model\", direction=\"completion\"}[1m]))", "legendFormat": "completion", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "tps", "min": 0}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "options": {"legend": {"showLegend": true, "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "title": "Outcome breakdown (last 5 min)",
      "type": "piechart",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum by (outcome) (increase(flock_requests_total{model=~\"$model\"}[5m]))", "legendFormat": "{{outcome}}", "refId": "A"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "options": {"legend": {"displayMode": "list", "placement": "right", "showLegend": true}, "pieType": "donut", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "tooltip": {"mode": "single"}}
    },
    {
      "title": "Nodes this model is loaded on",
      "type": "table",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "flock_model_loaded{model=~\"$model\"} == 1", "format": "table", "instant": true, "refId": "A"}
      ],
      "gridPos": {"h": 6, "w": 24, "x": 0, "y": 16},
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {"Time": true, "__name__": true, "Value": true, "instance": true, "job": true}, "renameByName": {"model": "Model", "node": "Node"}}}
      ],
      "options": {"showHeader": true}
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["flock"],
  "templating": {
    "list": [
      {
        "current": {"selected": false, "text": "default", "value": "default"},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": {"selected": true, "text": "All", "value": "$__all"},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "definition": "label_values(flock_requests_total, model)",
        "hide": 0,
        "includeAll": true,
        "label": "Model",
        "multi": false,
        "name": "model",
        "options": [],
        "query": {"query": "label_values(flock_requests_total, model)", "refId": "PrometheusVariableQueryEditor-VariableQuery"},
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Flock — Per-Model",
  "uid": "flock-per-model",
  "version": 1,
  "weekStart": ""
}
